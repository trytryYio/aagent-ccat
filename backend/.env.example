HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=INFO

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_IMAGE=product_images
QDRANT_COLLECTION_TEXT=product_knowledge

OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=your_key
OSS_ACCESS_KEY_SECRET=your_secret
OSS_BUCKET_NAME=agent-images
OSS_PREFIX=images/

LLM_API_KEY=sk-deepseek-xxx
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=60

MAX_IMAGE_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp

# 千问 DashScope rerank
DASHSCOPE_API_KEY=sk-xxx
RERANK_MODEL=gte-rerank-v2
RERANK_ENABLED=true

# 重排后端：local / dashscope / auto（默认 auto：优先本地 BGE，失败回退 DashScope）
RERANK_PROVIDER=auto
LOCAL_RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_DEVICE=auto

# 快速路径优化（高置信场景跳过 Rerank）
FAST_PATH_ENABLED=true
FAST_PATH_IMAGE_THRESHOLD=0.85
FAST_PATH_TEXT_THRESHOLD=0.75
FAST_PATH_HYBRID_IMAGE_THRESHOLD=0.90

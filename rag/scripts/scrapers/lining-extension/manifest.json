{
  "manifest_version": 3,
  "name": "李宁商品数据采集",
  "version": "1.0.0",
  "description": "从李宁官网提取商品数据，用于 RAG 向量化",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://store.lining.com/*",
    "*://api.store.lining.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "李宁商品数据采集",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://store.lining.com/goods/list*",
        "*://store.lining.com/goods/detail*"
      ],
      "js": ["content/content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
